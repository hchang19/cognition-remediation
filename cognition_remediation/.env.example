GITHUB_REPO=your-org/superset
GITHUB_WEBHOOK_SECRET=
DEVIN_API_KEY=
DEVIN_ORG_ID=
DEVIN_DAILY_SESSION_LIMIT=10
PAUSE=
DB_PATH=cognition.db

# Session limits — leave blank to disable
DEVIN_SESSION_COST_LIMIT_USD=   # e.g. 5.00 — terminate and comment if cost exceeds this
DEVIN_SESSION_TIME_LIMIT_MINUTES=  # e.g. 60 — terminate and comment if session runs longer than this
